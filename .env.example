# ─── Required ──────────────────────────────────────────────
# Anthropic API key. Required — the app cannot generate resources without it.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional ──────────────────────────────────────────────
# HTTP port. Railway sets this automatically; in local dev, 3000 is the default.
PORT=3000

# Comma-separated list of origins allowed to call the API cross-origin.
# Same-origin requests (the built-in frontend) always work without this.
# Only set this if you host the frontend on a different domain than the API.
# Example: ALLOWED_ORIGINS=https://resource-room.co.za,https://app.resource-room.co.za
ALLOWED_ORIGINS=

# Secret required to call GET /api/test. If unset, the endpoint returns 404.
# Set this only in environments where you want to probe the Anthropic key from a browser.
TEST_SECRET=

# Result cache — SQLite-backed cache of /api/generate responses. Identical
# requests within the TTL window return instantly at zero Anthropic cost.
# Default path: ./data/cache.db (created automatically).
# On Railway, mount a persistent volume and set this to a path on it (e.g.
# /data/cache.db) so the cache survives deploys.
CACHE_DB_PATH=

# Cache TTL in seconds. Default is 3600 (1 hour). Set to 0 for never-expire
# (two teachers with identical params would see the same paper forever — not
# usually what you want). Set to something like 600 for a shorter window.
CACHE_TTL_SECONDS=

# ─── Auth (Phase 2.4a, required in production) ──────────────
# HMAC key used to sign session cookies. Required in production (NODE_ENV=
# production) — the server will refuse to boot without it. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset in dev, a random ephemeral secret is generated each restart
# (sessions don't survive across restarts — fine for local development).
AUTH_SECRET=

# Base URL used to build magic-link verification URLs. Set this to your
# public URL in production, e.g. https://resource-room.up.railway.app
# In dev (localhost) you can leave it blank — links will be relative.
APP_URL=

# Email provider. "console" logs the email body to the pino logger (dev),
# "resend" sends via the Resend HTTP API (production), "disabled" is a no-op.
EMAIL_PROVIDER=console

# Resend API key. Required when EMAIL_PROVIDER=resend.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# "From" address used on transactional emails. Resend provides a sandbox
# address that works without domain verification — check the Resend docs
# for the current one. Verify your own domain in Resend to send from it.
# Example value:
#   EMAIL_FROM=The Resource Room <[email protected]>
EMAIL_FROM=
