# ─── Required ──────────────────────────────────────────────
# Anthropic API key. Required — the app cannot generate resources without it.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional ──────────────────────────────────────────────
# HTTP port. Railway sets this automatically; in local dev, 3000 is the default.
PORT=3000

# Comma-separated list of origins allowed to call the API cross-origin.
# Same-origin requests (the built-in frontend) always work without this.
# Only set this if you host the frontend on a different domain than the API.
# Example: ALLOWED_ORIGINS=https://resource-room.co.za,https://app.resource-room.co.za
ALLOWED_ORIGINS=

# Secret required to call GET /api/test. If unset, the endpoint returns 404.
# Set this only in environments where you want to probe the Anthropic key from a browser.
TEST_SECRET=
